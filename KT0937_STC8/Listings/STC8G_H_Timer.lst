  16          // КЏЪ§: u8 Timer_Inilize(u8 TIM, TIM_InitTypeDef *TIMx)
  17          // УшЪі: ЖЈЪБЦїГѕЪМЛЏГЬађ.
  18          // ВЮЪ§: TIMx: НсЙЙВЮЪ§,ЧыВЮПМtimer.hРяЕФЖЈвх.
  19          // ЗЕЛи: ГЩЙІЗЕЛи SUCCESS, ДэЮѓЗЕЛи FAIL.
  20          // АцБО: V1.0, 2012-10-22
  21          //========================================================================
  22          u8  Timer_Inilize(u8 TIM, TIM_InitTypeDef *TIMx)
  23          {
  24   1        if(TIM == Timer0)
  25   1        {
  26   2          Timer0_Stop();    //ЭЃжЙМЦЪ§
  27   2          if(TIMx->TIM_Mode > TIM_16BitAutoReloadNoMask)  return FAIL;  //ДэЮѓ
  28   2          TMOD = (TMOD & ~0x03) | TIMx->TIM_Mode; //ЙЄзїФЃЪН,0: 16ЮЛздЖЏжизА, 1: 16ЮЛЖЈЪБ/МЦЪ§, 2: 8ЮЛздЖЏжизА, 3:
             - ВЛПЩЦСБЮ16ЮЛздЖЏжизА
  29   2          if(TIMx->TIM_ClkSource >  TIM_CLOCK_Ext)  return FAIL;
  30   2          Timer0_CLK_Select(TIMx->TIM_ClkSource); //ЖдЭтМЦЪ§ЛђЗжЦЕ, ЖЈЪБ12T/1T
  31   2          Timer0_CLK_Output(TIMx->TIM_ClkOut);    //ЪфГіЪБжгЪЙФм
  32   2          T0_Load(TIMx->TIM_Value);
  33   2          Timer0_Run(TIMx->TIM_Run);
  34   2          return  SUCCESS;    //ГЩЙІ
  35   2        }
  36   1      
  37   1        if(TIM == Timer1)
  38   1        {
  39   2          Timer1_Stop();    //ЭЃжЙМЦЪ§
  40   2          if(TIMx->TIM_Mode > TIM_16BitAutoReloadNoMask)  return FAIL;  //ДэЮѓ
  41   2          TMOD = (TMOD & ~0x30) | (TIMx->TIM_Mode << 4);  //ЙЄзїФЃЪН,0: 16ЮЛздЖЏжизА, 1: 16ЮЛЖЈЪБ/МЦЪ§, 2: 8ЮЛздЖЏж
             -изА, 3: ЭЃжЙЙЄзї
  42   2          if(TIMx->TIM_ClkSource >  TIM_CLOCK_Ext)  return FAIL;
  43   2          Timer1_CLK_Select(TIMx->TIM_ClkSource); //ЖдЭтМЦЪ§ЛђЗжЦЕ, ЖЈЪБ12T/1T
  44   2          Timer1_CLK_Output(TIMx->TIM_ClkOut);    //ЪфГіЪБжгЪЙФм
  45   2          T1_Load(TIMx->TIM_Value);
  46   2          Timer1_Run(TIMx->TIM_Run);
  47   2          return  SUCCESS;    //ГЩЙІ
  48   2        }
  49   1      
  50   1        if(TIM == Timer2)   //Timer2,ЙЬЖЈЮЊ16ЮЛздЖЏжизА, жаЖЯЮогХЯШМЖ
  51   1        {
  52   2          Timer2_Stop();  //ЭЃжЙМЦЪ§
