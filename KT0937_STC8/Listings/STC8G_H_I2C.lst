 246          void Oled_Write_Data(u8 Data)   /* 向OLED 写入数据 */
 247          {
 248   1        Start();    SendData(0x78); //驱动地址 0x78
 249   1        RecvACK();  SendData(0x40); // 发送的只为字节D/C=100 0000为数据
 250   1        RecvACK();  SendData(Data);
 251   1        RecvACK();
 252   1        Stop();
 253   1      }
