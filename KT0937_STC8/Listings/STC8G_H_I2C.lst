  62          //========================================================================
  63          // 函数: void Wait (void)
  64          // 描述: 等待主机模式I2C控制器执行完成I2CMSCR.
  65          // 参数: none.
  66          // 返回: none.
  67          // 版本: V1.0, 2012-11-22
  68          //========================================================================
  69          void Wait()
  70          {
  71   1        while (!(I2CMSST & 0x40));
  72   1        I2CMSST &= ~0x40;
  73   1      }
  74          
