 312             /* 显示字符          列     行  字符内容       哪个数组 */
 313          void OLED_ShowChar(u8 x,u8 y,u8 car,u8 Char_Size)
 314          {       
 315   1        u8 c=0,i=0; 
 316   1        c = car-' ';   //偏移后的值     
 317   1        if(x>128-1)  {x=0;y=y+2;}
 318   1        if(Char_Size ==16)
 319   1          {
 320   2            OLED_Set_Points(x,y); 
 321   2            for(i=0;i<8;i++)
 322   2              { Oled_Write_Data(F8X16[c*16+i]); }
 323   2            OLED_Set_Points(x,y+1);
 324   2            for(i=0;i<8;i++)
 325   2              { Oled_Write_Data(F8X16[c*16+i+8]); }
 326   2          }
 327   1        else 
 328   1          { 
 329   2            OLED_Set_Points(x,y);
 330   2            for(i=0;i<6;i++)
 331   2              { Oled_Write_Data(F6x8[c][i]);  }
 332   2          }
 333   1      }
