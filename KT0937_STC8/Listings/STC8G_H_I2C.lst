 231          void Oled_Write_Cmd(u8 Comd)  /* 向OLED 写入命令 */
 232          {
 233   1        Start();  SendData(0x78); //驱动地址 0x78
 234   1        RecvACK();  SendData(0x00); // 发送的只为字节D/C=000 0000为命令
 235   1        RecvACK();  SendData(Comd);
 236   1        RecvACK();
 237   1        Stop();
 238   1      }
